{
  "name": "asciibattler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "fuzz": "tsx tests/fuzz/cli.ts",
    "fuzz:smoke": "vitest run --config vitest.fuzz.config.ts",
    "gauntlet": "tsx tests/gauntlet/cli.ts",
    "pathing": "tsx tests/pathing/cli.ts",
    "run-config": "tsx tools/run-config/cli.ts",
    "gen:sfx": "node scripts/gen-sfx.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "simplex-noise": "^4.0.3",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/three": "^0.184.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
