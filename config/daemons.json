{
  "daemons": [
    {
      "id": "mars",
      "name": "Idol of Mars",
      "description": "Once per turn, empower a unit: +4 STR / RNG / MAG for the encounter.",
      "rules": [
        {
          "kind": "hook",
          "on": "turnStart",
          "effect": {
            "op": "grantEmpowers",
            "empowersPerTurn": 1,
            "buff": {
              "key": "empowered",
              "mods": {
                "strength": { "add": 4 },
                "ranged": { "add": 4 },
                "magic": { "add": 4 }
              },
              "merge": "add"
            }
          }
        }
      ]
    },
    {
      "id": "minerva",
      "name": "Idol of Minerva",
      "description": "Once per turn, empower a unit: +2 DEF for the encounter.",
      "rules": [
        {
          "kind": "hook",
          "on": "turnStart",
          "effect": {
            "op": "grantEmpowers",
            "empowersPerTurn": 1,
            "buff": {
              "key": "warded",
              "mods": {
                "defense": { "add": 2 }
              },
              "merge": "add"
            }
          }
        }
      ]
    },
    {
      "id": "mercury",
      "name": "Idol of Mercury",
      "description": "Each turn, a coin flip: heads grants the full redraw.",
      "rules": [
        {
          "kind": "hook",
          "on": "turnStart",
          "chance": 0.5,
          "effect": {
            "op": "grantRedraws",
            "redrawsPerTurn": 1,
            "maxCardsPerTurn": 6
          }
        }
      ]
    },
    {
      "id": "janus",
      "name": "Idol of Janus",
      "description": "Every turn, redraw up to two cards.",
      "rules": [
        {
          "kind": "hook",
          "on": "turnStart",
          "effect": {
            "op": "grantRedraws",
            "redrawsPerTurn": 1,
            "maxCardsPerTurn": 2
          }
        }
      ]
    },
    {
      "id": "moneta",
      "name": "Idol of Moneta",
      "description": "All bits earned are increased by 20%.",
      "rules": [
        {
          "kind": "modifier",
          "stat": "bitsGain",
          "op": "mult",
          "value": 1.2
        }
      ]
    },
    {
      "id": "laverna",
      "name": "Idol of Laverna",
      "description": "Each blow a rogue lands earns a bit.",
      "rules": [
        {
          "kind": "hook",
          "on": "dealHit",
          "filter": { "archetype": "rogue" },
          "effect": {
            "op": "gainBits",
            "amount": 1
          }
        }
      ]
    },
    {
      "id": "fortuna",
      "name": "Idol of Fortuna",
      "description": "A critical strike emboldens the striker: +1 STR / RNG / MAG for 5s.",
      "rules": [
        {
          "kind": "hook",
          "on": "dealHit",
          "filter": { "crit": true },
          "effect": {
            "op": "applyStatus",
            "statusId": "emboldened"
          }
        }
      ]
    }
  ]
}
